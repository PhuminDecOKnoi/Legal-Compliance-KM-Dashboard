<article class="panel">
  <div class="panel-header">
    <h3><%= t.backlog %></h3>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t.legalTitle %></th>
          <th><%= t.category %></th>
          <th><%= t.status %></th>
          <th><%= t.validity %></th>
          <th><%= t.requiredAction %></th>
          <th><%= t.notes %></th>
        </tr>
      </thead>
      <tbody>
        <% appData.backlog.forEach((item) => { %>
          <tr>
            <td><%= item.legalTitle %></td>
            <td><%= ui.localizeCategory(item.category) %></td>
            <td><span class="badge"><%= ui.localizeStatus(item.status) %></span></td>
            <td><span class="badge <%= item.validity === 'Active' ? 'badge-active' : 'badge-muted' %>"><%= ui.localizeValidity(item.validity) %></span></td>
            <td><%= item.requiredAction %></td>
            <td><%= ui.localizeNote(item.notes) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</article>
