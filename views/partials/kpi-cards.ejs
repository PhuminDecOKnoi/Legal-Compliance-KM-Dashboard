<section class="kpi-grid">
  <article class="kpi-card">
    <span><%= t.totalLegalRequirements %></span>
    <strong><%= appData.kpis.totalLegalRequirements %></strong>
  </article>
  <article class="kpi-card">
    <span><%= t.activeLaws %></span>
    <strong><%= appData.kpis.activeLaws %></strong>
  </article>
  <article class="kpi-card">
    <span><%= t.implemented %></span>
    <strong><%= appData.kpis.implemented %></strong>
