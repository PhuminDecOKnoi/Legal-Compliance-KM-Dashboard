<header class="app-header">
  <div class="brand-block">
    <div>
      <p class="eyebrow"><%= t.reportingMonth %></p>
      <h1><%= t.appTitle %></h1>
    </div>
    <div class="meta-stack">
      <span><strong><%= t.reportingMonth %>:</strong> <%= appData.meta.reportingMonth %></span>
      <span><strong><%= t.sourceFile %>:</strong> <%= appData.meta.sourceFileName %></span>
      <span><strong><%= t.lastUpdated %>:</strong> <%= new Date(appData.meta.lastUpdatedIso).toLocaleString() %></span>
    </div>
  </div>
  <div class="toolbar">
    <div class="toolbar-group">
      <label for="lang-switch"><%= t.bilingualMode %></label>
      <select id="lang-switch" class="lang-switch">
        <option value="en" <%= locale === 'en' ? 'selected' : '' %>>English</option>
        <option value="th" <%= locale === 'th' ? 'selected' : '' %>>ไทย</option>
      </select>
    </div>
    <div class="toolbar-group view-toggle">
      <a class="chip <%= currentPath.includes('/executive') || currentPath === '/dashboard' ? 'active' : '' %>" href="<%= url.route('/dashboard/executive', locale) %>"><%= t.executiveView %></a>
      <a class="chip <%= currentPath.includes('/employee') || currentPath === '/legal-register' ? 'active' : '' %>" href="<%= url.route('/dashboard/employee', locale) %>"><%= t.employeeView %></a>
      <a class="chip <%= currentPath.includes('/admin') ? 'active' : '' %>" href="<%= url.route('/admin', locale) %>"><%= t.admin %></a>
    </div>
    <div class="toolbar-group">
      <% if (!url.staticMode) { %>
        <button id="refresh-data" class="button button-secondary"><%= t.refreshData %></button>
        <a class="button" href="/export/pdf?view=<%= currentPath.includes('/employee') || currentPath.includes('/legal-register') ? 'employee' : 'executive' %>&lang=<%= locale %>"><%= t.exportPdf %></a>
        <a class="button button-secondary" href="/export/excel?lang=<%= locale %>"><%= t.exportExcel %></a>
        <a class="button button-secondary" href="<%= currentPath.includes('/employee') || currentPath.includes('/legal-register') ? '/print/employee' : '/print/executive' %>?lang=<%= locale %>" target="_blank" rel="noreferrer"><%= t.printView %></a>
        <% if (adminUser) { %>
          <form method="post" action="/admin/logout?lang=<%= locale %>">
            <input type="hidden" name="lang" value="<%= locale %>" />
            <button class="button button-secondary" type="submit"><%= t.signOut %></button>
          </form>
        <% } %>
      <% } else { %>
        <a class="button button-secondary" href="<%= url.route(currentPath.includes('/employee') || currentPath.includes('/legal-register') ? '/print/employee' : '/print/executive', locale) %>" target="_blank" rel="noreferrer"><%= t.printView %></a>
      <% } %>
    </div>
  </div>
</header>

<nav class="main-nav">
  <a href="<%= url.route('/dashboard', locale) %>" class="<%= currentPath === '/dashboard' ? 'active' : '' %>"><%= t.dashboard %></a>
  <a href="<%= url.route('/dashboard/executive', locale) %>" class="<%= currentPath === '/dashboard/executive' ? 'active' : '' %>"><%= t.executiveView %></a>
  <a href="<%= url.route('/dashboard/employee', locale) %>" class="<%= currentPath === '/dashboard/employee' ? 'active' : '' %>"><%= t.employeeView %></a>
  <a href="<%= url.route('/legal-register', locale) %>" class="<%= currentPath === '/legal-register' ? 'active' : '' %>"><%= t.legalRegister %></a>
  <a href="<%= url.route('/backlog', locale) %>" class="<%= currentPath === '/backlog' ? 'active' : '' %>"><%= t.backlog %></a>
  <a href="<%= url.route('/category-summary', locale) %>" class="<%= currentPath === '/category-summary' ? 'active' : '' %>"><%= t.categorySummary %></a>
  <a href="<%= url.route('/trend-summary', locale) %>" class="<%= currentPath === '/trend-summary' ? 'active' : '' %>"><%= t.trendSummary %></a>
  <a href="<%= url.route('/data-quality', locale) %>" class="<%= currentPath === '/data-quality' ? 'active' : '' %>"><%= t.dataQuality %></a>
  <a href="<%= url.route('/about-report', locale) %>" class="<%= currentPath === '/about-report' ? 'active' : '' %>"><%= t.aboutReport %></a>
  <a href="<%= url.route('/admin', locale) %>" class="<%= currentPath.startsWith('/admin') ? 'active' : '' %>"><%= t.admin %></a>
</nav>
