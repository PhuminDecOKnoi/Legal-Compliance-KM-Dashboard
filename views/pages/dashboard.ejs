<%- include('../partials/head') %>
<main class="shell">
  <%- include('../partials/header') %>
  <%- include('../partials/kpi-cards') %>
  <section class="dashboard-grid">
    <article class="panel hero-panel">
      <div class="panel-header">
        <h2><%= t.executiveHighlights %></h2>
      </div>
      <p class="lead"><%= insights.narrative %></p>
      <p class="source-note"><%= t.sourceLanguageNote %></p>
      <div class="recommendation-strip">
        <% insights.recommendations.executive.forEach((item) => { %>
          <div class="recommendation-card"><%= item %></div>
        <% }) %>
      </div>
    </article>
    <%- include('../partials/chart-card', { title: t.categorySummary, subtitle: t.byCategoryCount, data: viewModel.categoryChartData, type: 'bar' }) %>
    <%- include('../partials/chart-card', { title: t.trendSummary, subtitle: t.monthlyDistribution, data: viewModel.monthlyTrendChartData, type: 'line' }) %>
  </section>
  <section class="two-col">
    <%- include('../partials/category-table') %>
    <%- include('../partials/data-quality-panel') %>
  </section>
  <%- include('../partials/backlog-table') %>
</main>
<%- include('../partials/footer') %>
