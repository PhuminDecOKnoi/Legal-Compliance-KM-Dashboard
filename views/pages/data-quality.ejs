<%- include('../partials/head') %>
<main class="shell">
  <%- include('../partials/header') %>
  <section class="two-col">
    <%- include('../partials/data-quality-panel') %>
    <article class="panel">
      <div class="panel-header">
        <h3><%= t.legalRegister %></h3>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>No</th>
              <th><%= t.legalTitle %></th>
              <th><%= t.dataQualityFlags %></th>
            </tr>
          </thead>
          <tbody>
            <% appData.records.filter(record => record.dataQualityFlags.length).forEach((record) => { %>
              <tr>
                <td><%= record.no %></td>
                <td><%= record.legalTitle %></td>
                <td><%= record.dataQualityFlags.map(flag => ui.localizeNote(flag)).join(', ') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </article>
  </section>
</main>
<%- include('../partials/footer') %>
